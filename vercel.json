{
  "functions": {
    "api/analyze.js": {
      "maxDuration": 60
    },
    "api/transcribe.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/transcribe", "destination": "/api/transcribe.js" },
    { "source": "/api/analyze", "destination": "/api/analyze.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
